# === Network ===
# Sui network: testnet | mainnet
LYRA_NETWORK=testnet

# === Lyra Move package ===
# Deployed lyra package id (see deployments/<network>.json).
LYRA_PACKAGE_ID=0x660c443a027823dd2befba62588449c801d99566f16cdd5376b6b986dafc64bf

# === Agent key ===
# Ed25519 private key for the agent's operational address.
# Bech32 `suiprivkey1...` (preferred) or base64. NEVER commit a real key.
LYRA_AGENT_KEY=

# === Policy (deterministic guardrails — the off-chain mirror of AgentPolicy) ===
LYRA_POLICY_MAX_PER_TX_SUI=1.0          # hard per-action cap
LYRA_POLICY_AUTO_MAX_SUI=0.1            # auto-execute at/under this; above -> require approval
LYRA_POLICY_MAX_SLIPPAGE_BPS=100        # block swaps over 1% slippage
LYRA_POLICY_AUTONOMY=auto               # auto | confirm | readonly
LYRA_POLICY_ALLOWED_PROTOCOLS=transfer,deepbook,walrus
LYRA_POLICY_ALLOWED_COINS=0x2::sui::SUI
LYRA_POLICY_EXPIRY_MINUTES=60

# === LLM brain (OpenAI-compatible) — used by the agent in a later phase ===
OPENAI_API_KEY=
LYRA_LLM_BASE_URL=https://api.openai.com/v1
LYRA_LLM_MODEL=gpt-4o-mini

# === Walrus (durable receipts / memory) ===
WALRUS_NETWORK=testnet
