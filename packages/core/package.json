{
  "name": "lyra-core",
  "version": "0.1.1",
  "type": "module",
  "description": "The SDK for lyra, a Sui-native policy-aware AI treasury assistant: brain, local memory + storage, the policy/approval engine, and the Sui agent keypair + chain helpers",
  "license": "MIT",
  "homepage": "https://github.com/rifkyeasy/lyra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rifkyeasy/lyra.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/rifkyeasy/lyra/issues"
  },
  "keywords": [
    "lyra",
    "ai",
    "agent",
    "sui",
    "treasury",
    "defi",
    "policy"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./events": "./src/events/index.ts",
    "./memory": "./src/memory/index.ts",
    "./tools": "./src/tools/index.ts",
    "./brain": "./src/brain/index.ts",
    "./storage": "./src/storage/index.ts",
    "./wallet": "./src/wallet/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./paths": "./src/paths.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "bun test"
  },
  "dependencies": {
    "@mysten/sui": "^1.40.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "gray-matter": "^4.0.3",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2"
  }
}
